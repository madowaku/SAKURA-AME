<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="widget_name">桜雨ウィジェット</string>
    <string-array name="widget_quotes">
        <item>雨の音に、心を寄せて</item>
        <item>静寂は、波紋のなかに</item>
        <item>時の流れを、音に聴く</item>
        <item>静かな庭で、自分と向き合う</item>
        <item>一滴の雫が、世界を揺らす</item>
        <item>雨上がり、虹を待つ心</item>
        <item>風のささやき、花の溜息</item>
        <item>今日の雨が、明日の花を咲かせる</item>
        <item>揺れる花びら、変わらぬ静けさ</item>
        <item>雨の音は、空からの手紙</item>
    </string-array>
</resources>
